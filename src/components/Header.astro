---
const currentPath = Astro.url.pathname;

const navigation = [
	{ href: '/', label: 'Home' },
	{ href: '/archive', label: 'Archive' },
	{ href: '/about', label: 'About' },
];
---

<header class="site-header">
	<div class="header-inner">
		<a class="brand" href="/" aria-label="Linahhsheng 首頁">Linahhsheng</a>

		<nav aria-label="主要導覽">
			<ul>
				{
					navigation.map((item) => {
						const isActive = currentPath === item.href;
						return (
							<li>
								<a href={item.href} aria-current={isActive ? 'page' : undefined}>
									{item.label}
								</a>
							</li>
						);
					})
				}
			</ul>
		</nav>
	</div>
</header>

<style>
	.site-header {
		border-bottom: 1px solid #e5e7eb;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		width: min(100% - 3rem, 720px);
		min-height: 72px;
		margin: 0 auto;
	}

	.brand {
		flex: 0 0 auto;
		font-size: 0.9375rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	ul {
		display: flex;
		gap: 1.25rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	nav a {
		color: #666666;
		font-size: 0.875rem;
	}

	nav a:hover,
	nav a:focus-visible,
	nav a[aria-current='page'] {
		color: #222222;
	}

	nav a:hover,
	nav a:focus-visible {
		text-decoration: underline;
		text-decoration-color: #ff7575;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.35em;
	}

	nav a:focus-visible {
		outline: 2px solid #ff7575;
		outline-offset: 4px;
		border-radius: 2px;
	}

	@media (max-width: 480px) {
		.header-inner {
			gap: 1rem;
			width: min(100% - 2rem, 720px);
		}

		ul {
			gap: 0.875rem;
		}
	}
</style>
