---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Linahhsheng',
	description = '記錄我ㄉ笙活。',
} = Astro.props;

const pageTitle = title === 'Linahhsheng' ? title : `${title} · Linahhsheng`;
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/S.png" />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Shared shell keeps every route on the same calm reading grid. -->
		<div class="site-shell">
			<Header />
			<main>
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
