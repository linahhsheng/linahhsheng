---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('posts')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = allPosts.slice(0, 5);
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort((a, b) =>
	a.localeCompare(b, 'zh-Hant'),
);
---

<Layout>
	<div class="home-stage">
		<aside class="profile-card" aria-label="個人簡介">
			<img src="/media/profile.jpg" alt="我和 Binky" width="140" height="140" />
			<p>這是我和 Binky！</p>
		</aside>

		<div class="page-container">
		<section class="hero" aria-labelledby="page-title">
			<h1 id="page-title">Linahhsheng</h1>
			<p class="subtitle">記錄我ㄉ笙活。</p>
			<p class="topics">Life · Badminton · Music · Gaming</p>
		</section>

		<section class="latest-posts" aria-labelledby="latest-posts-title">
			<div class="tag-filters" aria-label="文章 Tag 篩選">
				<button class="tag-filter is-selected" type="button" data-tag-filter="all" aria-pressed="true">
					全部
				</button>
				{allTags.map((tag) => (
					<button class="tag-filter" type="button" data-tag-filter={tag} aria-pressed="false">
						{tag}
					</button>
				))}
			</div>

			<div class="section-heading">
				<h2 id="latest-posts-title">Latest Posts</h2>
				<span data-post-count>{latestPosts.length} 篇</span>
			</div>

			<div class="post-list">
				{latestPosts.map((post) => <PostCard post={post} />)}
			</div>
			<p class="empty-state" data-empty-state hidden>沒有符合的文章。</p>
		</section>
		</div>
	</div>
</Layout>

<script>
	const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]');
	const postCards = document.querySelectorAll<HTMLElement>('[data-post-card]');
	const postCount = document.querySelector<HTMLElement>('[data-post-count]');
	const emptyState = document.querySelector<HTMLElement>('[data-empty-state]');
	const selectedTags = new Set<string>();

	function updatePosts() {
		const activeTags = [...selectedTags];
		let visibleCount = 0;

		postCards.forEach((card) => {
			const cardTags = (card.dataset.tags ?? '').split('|').filter(Boolean);
			const isVisible = activeTags.length === 0 || activeTags.some((tag) => cardTags.includes(tag));

			card.hidden = !isVisible;
			if (isVisible) visibleCount += 1;
		});

		if (postCount) postCount.textContent = `${visibleCount} 篇`;
		if (emptyState) emptyState.hidden = visibleCount !== 0;

		filterButtons.forEach((button) => {
			const tag = button.dataset.tagFilter;
			const isAll = tag === 'all';
			button.classList.toggle('is-selected', isAll ? activeTags.length === 0 : selectedTags.has(tag ?? ''));
			button.setAttribute('aria-pressed', String(isAll ? activeTags.length === 0 : selectedTags.has(tag ?? '')));
		});
	}

	filterButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const tag = button.dataset.tagFilter;

			if (tag === 'all') {
				selectedTags.clear();
			} else if (tag) {
				selectedTags.has(tag) ? selectedTags.delete(tag) : selectedTags.add(tag);
			}

			updatePosts();
		});
	});
</script>

<style>
	.home-stage {
		position: relative;
	}

	.profile-card {
		position: absolute;
		top: 5.5rem;
		left: calc(50% - 560px);
		width: 140px;
		margin: 0;
		text-align: center;
	}

	.profile-card img {
		display: block;
		width: 140px;
		height: 140px;
		border-radius: 50%;
		object-fit: cover;
	}

	.profile-card p {
		margin: 0.75rem 0 0;
		color: #666666;
		font-size: 13px;
		line-height: 1.5;
		white-space: nowrap;
	}

	.page-container {
		width: min(100% - 3rem, 720px);
		padding: 5.5rem 0 6rem;
		margin: 0 auto;
	}

	.hero {
		padding-bottom: 5.5rem;
	}

	h1,
	h2 {
		letter-spacing: -0.04em;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.5rem, 8vw, 4rem);
		font-weight: 700;
		line-height: 1.1;
	}

	.subtitle {
		margin: 1rem 0 0;
		color: #666666;
		font-size: 1.125rem;
	}

	.topics {
		margin: 1.25rem 0 0;
		color: #666666;
		font-size: 0.8125rem;
		letter-spacing: 0.01em;
	}

	.tag-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	.tag-filter {
		padding: 0.25rem 0.625rem;
		border: 1px solid #e5e7eb;
		border-radius: 999px;
		background: transparent;
		color: #666666;
		cursor: pointer;
		font-size: 0.75rem;
		line-height: 1.5;
		transition: background-color 150ms ease, border-color 150ms ease, color 150ms ease;
	}

	.tag-filter:hover,
	.tag-filter:focus-visible {
		border-color: #ff7575;
		color: #ff7575;
	}

	.tag-filter.is-selected {
		border-color: #ff7575;
		background: #ff7575;
		color: #ffffff;
	}

	.tag-filter:focus-visible {
		outline: 2px solid #ff7575;
		outline-offset: 3px;
	}

	.post-list [hidden] {
		display: none;
	}

	.empty-state {
		margin: 2rem 0 0;
		color: #666666;
		font-size: 0.9375rem;
	}

	.section-heading {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.25rem;
	}

	h2 {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 600;
	}

	.section-heading span {
		color: #666666;
		font-size: 0.8125rem;
	}

	@media (max-width: 480px) {
		.profile-card {
			position: static;
			margin: 2rem auto 0;
		}

		.page-container {
			width: min(100% - 2rem, 720px);
			padding: 4rem 0;
		}

		.hero {
			padding-bottom: 4rem;
		}
	}
</style>
